Cell[CellGroupData[{

Cell["\<\
Exercise2
Use a tagged assignment to set up an evaluation rule to replace any integer \
power of any expression of the form x[_]
 with zero.\
\>", "Subsection",
 CellChangeTimes->{{3.985704238376772*^9, 
  3.9857042405561943`*^9}},ExpressionUUID->"13aa4a3e-6736-1840-a468-\
