Cell[CellGroupData[{

Cell["\<\
Exercise3
Use FullForm and StringReplace to write a function names[list_] that returns \
the names of special characters, as shown below:\
\>", "Subsection",
 CellChangeTimes->{{3.9856609601449146`*^9, 
  3.9856609651907215`*^9}},ExpressionUUID->"91bfaf89-b040-8546-8311-\
75b5bba398ac"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"names", "[", "list_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"StringReplace", "[", 
     RowBox[{
      RowBox[{"ToString", "@", 
       RowBox[{"FullForm", "[", "#", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<\\\\[\>\"", "->", "\"\<\>\""}], ",", 
        RowBox[{"\"\<]\>\"", "->", "\"\<\>\""}]}], "}"}]}], "]"}], "&"}], "/@",
    "list"}]}], "\[IndentingNewLine]", 
 RowBox[{"names", "@", 
  RowBox[{"{", 
   RowBox[{
   "\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", "\[Delta]", ",", 
    "\[CurlyEpsilon]", ",", "\[Zeta]", ",", "\[Eta]", ",", "\[Theta]", ",", 
    "\[Iota]", ",", "\[Kappa]", ",", "\[Lambda]", ",", "\[Mu]", ",", "\[Nu]", 
    ",", "\[Xi]", ",", "\[Omicron]", ",", "\[Pi]", ",", "\[Rho]", ",", 
    "\[Sigma]", ",", "\[Tau]", ",", "\[Upsilon]", ",", "\[CurlyPhi]", ",", 
    "\[Chi]", ",", "\[Psi]", ",", "\[Omega]"}], "}"}]}]}], "Input",
 CellChangeTimes->{{3.9856609721760426`*^9, 3.9856609721760426`*^9}, {
