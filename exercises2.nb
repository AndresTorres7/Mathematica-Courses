  3.9857043255590305`*^9}},ExpressionUUID->"c8cb397a-03bb-d540-b8ee-\
187f654264ac"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Exercise3
Use assignments in a Do loop to create evaluation rules to replace g[n][p_] \
with f[np] for n from 1 to 10.\
\>", "Subsection",
 CellChangeTimes->{{3.985704383683243*^9, 
  3.985704389654022*^9}},ExpressionUUID->"46240dd5-0206-0444-8afd-\
23ba406efe12"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "g", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"g", "[", "n", "]"}], "[", "p_", "]"}], " ", "=", " ", 
    RowBox[{"f", "[", 
     RowBox[{"n", " ", "p"}], "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "10"}], "}"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9857043960051765`*^9, 
  3.9857044495171814`*^9}},ExpressionUUID->"e28a558c-a963-1a4c-a28c-\
22732ab8c4af"]
}, Open  ]]
}, Open  ]],

