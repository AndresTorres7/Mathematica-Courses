 RowBox[{"Panel", "[", 
  RowBox[{"Column", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Slider", "[", 
      RowBox[{
       RowBox[{"Dynamic", "[", "n", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "10", ",", "1"}], "}"}], ",", 
       RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "]"}], ",", 
