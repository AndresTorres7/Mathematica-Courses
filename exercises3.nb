Cell[CellGroupData[{

Cell["Exercises: Making Plots of Data", "Section",
 CellChangeTimes->{{3.985759446512493*^9, 3.9857594492806644`*^9}, {
  3.9857596883198586`*^9, 
  3.985759693391239*^9}},ExpressionUUID->"4ea091ac-bd25-724b-aff6-\
dd85ab5b4026"],

Cell[CellGroupData[{

Cell["\<\
Exercise1
Modify this input so that the vertical scale is logarithmic and so the data \
is shown with plot markers with style 
Style[\[OpenCurlyDoubleQuote]\[FilledSquare]\[CloseCurlyDoubleQuote],Large,\
Blue]  joined by straight lines. Lines joining plot markers can be specified \
using the option 
Joined\[Rule]True:\
\>", "Subsection",
 CellChangeTimes->{{3.98575970970883*^9, 
  3.9857597193583755`*^9}},ExpressionUUID->"f56a625c-e542-9e45-b98a-\
4fb01b0194d5"],

