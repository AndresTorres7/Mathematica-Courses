Cell[CellGroupData[{

Cell["Exercises: Function Visualization", "Section",
 CellChangeTimes->{{3.9857857913812103`*^9, 
  3.985785800644045*^9}},ExpressionUUID->"609d940d-898f-6f43-88d8-\
0bb56b50cc8f"],

Cell[CellGroupData[{

Cell["\<\

Exercise1
Make a plot of the functions Exp[x], Exp[2x] and x^5, all on the same plot, \
for 1<x<10, and with a logarithmic vertical scale. Include the options \
GridLines\[Rule]Automatic and Frame\[Rule]True so that the plot is drawn with \
grid lines and a frame.\
\>", "Subsection",
 CellChangeTimes->{{3.985785874714855*^9, 
  3.9857858888200836`*^9}},ExpressionUUID->"02694fb5-ebd8-614c-b45f-\
202a75ff4195"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Exp", "[", "x", "]"}], ",", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"2", "x"}], "]"}], ",", " ", 
     RowBox[{"x", "^", "5"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "1", ",", "10"}], "}"}], ",", 
   RowBox[{"ScalingFunctions", "->", "\"\<Log\>\""}], ",", " ", 
   RowBox[{"GridLines", "->", "Automatic"}], ",", 
   RowBox[{"Frame", "->", "True"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.985787162727669*^9, 3.9857872964633694`*^9}},
 CellLabel->
  "In[121]:=",ExpressionUUID->"423db299-9ea4-4948-9c23-5120f15ae5b7"],

