Cell[CellGroupData[{

Cell["\<\
Exercise1
Use Hold and InputForm to get Argentina\:f010populationYear:2010\:f016 in \
InputForm format(formattedusingexplicitEntityandEntityPropertyexpressions).\
\>", "Subsection",
 CellChangeTimes->{{3.9857563044708347`*^9, 
  3.9857563741094456`*^9}},ExpressionUUID->"c88a4714-62b0-334b-9cd8-\
3538391d9b23"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    TemplateBox[{"\"Argentina\"", 
      RowBox[{"Entity", "[", 
        RowBox[{"\"Country\"", ",", "\"Argentina\""}], "]"}], 
      "\"Entity[\\\"Country\\\", \\\"Argentina\\\"]\"", "\"country\""},
     "Entity"], "[", 
    InterpretationBox[
     DynamicModuleBox[{EntityFramework`Formatting`Private`open = False}, 
      TemplateBox[{
        TemplateBox[{"\"population\""}, "ImplicitEntityPropertyBase"], 
        GridBox[{{
           TemplateBox[{
             RowBox[{" ", "\"Date\""}], "\":\"", 
             TemplateBox[{
               RowBox[{
                 StyleBox["\"Year: \"", "DateObjectLabel"], "\"2010\""}], 
               RowBox[{"DateObject", "[", 
                 RowBox[{
                   RowBox[{"{", "2010", "}"}], ",", "\"Year\""}], "]"}]}, 
              "DateObject", Editable -> False]}, "ImplicitEntityInfoRow"]}}, 
         DefaultBaseStyle -> "GeneralizedEntityInfoGrid", 
         GridBoxAlignment -> {"Columns" -> {{Left}}}], 
        Dynamic[EntityFramework`Formatting`Private`open], 
        "\"EntityProperty[\\\"Country\\\", \\\"Population\\\", {\\\"Date\\\" \
-> DateObject[{2010}]}]\"", 
        TemplateBox[{
          TemplateBox[{
            RowBox[{
              StyleBox["\"Year: \"", "DateObjectLabel"], "\"2010\""}], 
            RowBox[{"DateObject", "[", 
              RowBox[{
                RowBox[{"{", "2010", "}"}], ",", "\"Year\""}], "]"}]}, 
           "DateObject", Editable -> False]}, 
         "ImplicitEntityPropertySequence"]},
       "ImplicitEntityPropertyToggle"]],
     EntityProperty["Country", "Population", {"Date" -> DateObject[{2010}]}],
     SelectWithContents->True], "]"}], "//", "Hold"}], " ", "//", 
  "InputForm"}]], "Input",
 CellChangeTimes->{{3.9857569916201344`*^9, 3.985757000881836*^9}},
 CellLabel->"In[87]:=",ExpressionUUID->"790baad2-6738-f340-bcb4-b834403dad12"],

Cell["\<\
Hold[Entity[\"Country\", \"Argentina\"][EntityProperty[\"Country\", \
\"Population\", {\"Date\" -> DateObject[{2010}]}]]]\
\>", "Output",
 CellChangeTimes->{3.9857569282540665`*^9, 3.985757002023155*^9},
 CellLabel->
  "Out[87]//InputForm=",ExpressionUUID->"0a26cdcd-194a-e448-951c-\
3ac29ad93f9b"]
}, Open  ]]
}, Open  ]],

