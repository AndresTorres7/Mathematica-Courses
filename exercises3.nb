Cell[CellGroupData[{

Cell["\<\
Exercise2
Add callout labels to the lines in this plot to label each line with the \
mathematical expression for the corresponding function. That is, the plot of \
Sqrt[x]Cos[x] should be labeled with xcos(x) and the plot of 
Sin[x] should be labeled with sin(x):\
\>", "Subsection",
 CellChangeTimes->{{3.9857879181833096`*^9, 
  3.985787926827814*^9}},ExpressionUUID->"0c391eec-881c-c24c-b003-\
72754ce48443"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Callout", "[", 
      RowBox[{
       RowBox[{"Sqrt", "[", "x", "]"}], " ", 
       RowBox[{"Cos", "[", "x", "]"}]}], "]"}], ",", 
     RowBox[{"Callout", "[", 
      RowBox[{"Sin", "[", "x", "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "5"}], "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.985787935262764*^9, 3.9857879352637863`*^9}, 
   3.985788961370825*^9, {3.9857890618560143`*^9, 3.9857890890824833`*^9}},
