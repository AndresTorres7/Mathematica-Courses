Cell[CellGroupData[{

Cell["\<\

Exercise3
Change this bar chart so that the bars start on the left side of the chart \
and extend to the right, and add a frame and labels in 12 point font with \
label A for the first bar, B for the second bar, C for the third bar, D for \
the fourth bar and E for the fifth bar:\
\>", "Subsection",
 CellChangeTimes->{
  3.9857879726633224`*^9},ExpressionUUID->"3da02c1a-3e9e-f947-a63c-\
7fc0bf1c39a8"],

