Cell[CellGroupData[{

Cell["\<\
Exercise1
Use Map and a pure function to get the same result as the result from this \
program:
x={{2,3},{3,4},{4,5}};
\:200b\:200bDo[x[[i]]=x[[i,1]]Cos[x[[i,2]]],{i,3}];\:200b\:200bx
{2Cos[3],3Cos[4],4Cos[5]}\
\>", "Subsection",
 CellChangeTimes->{{3.9856270670481815`*^9, 
  3.985627077233612*^9}},ExpressionUUID->"aba871aa-315e-1242-bd1c-\
0b0cb4451b7b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "4"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"4", ",", "5"}], "}"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "[", 
      RowBox[{"[", "i", "]"}], "]"}], "=", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", 
        RowBox[{"i", ",", "1"}], "]"}], "]"}], 
      RowBox[{"Cos", "[", 
       RowBox[{"x", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "2"}], "]"}], "]"}], "]"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "3"}], "}"}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", "x"}], "Input",
 CellChangeTimes->{{3.985627084430889*^9, 3.985627084430889*^9}, {
  3.985627392109827*^9, 3.9856274094982185`*^9}, {3.985627462309681*^9, 
