Cell[CellGroupData[{

Cell["\<\
Exercise6
Use ReplaceAll and a pair of rules to get the same result as from this program:
x={1,2,\[Pi],4,5};
\:200b\:200bDo[Which[EvenQ[x[[i]]],x[[i]]/=2,OddQ[x[[i]]],x[[i]]*=10],{i,5}];x
{10,1,\[Pi],2,50}\
\>", "Subsection",
 CellChangeTimes->{3.985617006694254*^9, 
  3.985617059907444*^9},ExpressionUUID->"ab0245f1-b8c9-3e44-8ecf-\
2caa7c1a08dc"],

