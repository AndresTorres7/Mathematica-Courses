Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "\[Pi]", ",", "4", ",", "5"}], "}"}], "/.", 
  " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"x_", "?", "EvenQ"}], "  ", ":>", " ", 
     RowBox[{"x", "/", "2"}]}], " ", ",", " ", 
    RowBox[{
     RowBox[{"x_", "?", "OddQ"}], " ", ":>", " ", 
     RowBox[{"x", "*", "10"}]}]}], "}"}]}]], "Input",
 CellChangeTimes->{{3.9854779198753223`*^9, 3.985477920336994*^9}, {
   3.9856168597411556`*^9, 3.9856168894610806`*^9}, 3.985616969496069*^9, 
