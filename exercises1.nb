Cell[CellGroupData[{

Cell["Exercises Rule-Based Programming", "Section",
 CellChangeTimes->{{3.9856468385372543`*^9, 
  3.9856468522532787`*^9}},ExpressionUUID->"8e6dea9f-b2bd-254d-a4c8-\
a6c4d8772c30"],

Cell[CellGroupData[{

Cell["\<\

Exercise1
Write a rule-based program to do what the Expand function does, using \
ReplaceRepeated and a rule that replaces any expression of the form p_(q_+r_) \
 with pq+pr.\
\>", "Subsection",
 CellChangeTimes->{{3.985646877478819*^9, 3.9856468867186775`*^9}, {
  3.9856469249123306`*^9, 
  3.98564692751713*^9}},ExpressionUUID->"1e64ec66-5c0a-4244-9e2b-\
f3d82c754887"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Expand", "[", 
  RowBox[{"5", 
   RowBox[{"(", 
    RowBox[{"x", "+", "3"}], ")"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.985646931403635*^9, 3.9856469829127274`*^9}, {
  3.985647024635311*^9, 3.9856470648619556`*^9}, {3.9856470984678936`*^9, 
  3.9856471261131954`*^9}, {3.9856472432421284`*^9, 3.985647267284004*^9}, {
  3.985647332420269*^9, 3.985647343051815*^9}, {3.9856482501112423`*^9, 
  3.985648253236538*^9}},
 CellLabel->
  "In[176]:=",ExpressionUUID->"5efd6e98-73ba-1c45-90b7-79cf709b14cf"],

Cell[BoxData[
 RowBox[{"15", "+", 
  RowBox[{"5", " ", "x"}]}]], "Output",
 CellChangeTimes->{{3.9856469777776318`*^9, 3.985646983566948*^9}, {
   3.98564704734692*^9, 3.9856470653509064`*^9}, 3.9856471272417984`*^9, {
   3.9856472388476696`*^9, 3.985647267958893*^9}, {3.985648241389971*^9, 
   3.985648254159525*^9}},
 CellLabel->
  "Out[176]=",ExpressionUUID->"49dc4d15-146a-3d49-ae5a-1c3ec52dbffb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "b", "+", "1"}], ")"}], "a"}], "+", "b", "+", "1"}], 
    ")"}], 
   RowBox[{"(", 
    RowBox[{"x", "+", "y", "+", "2"}], ")"}]}], "//.", 
  RowBox[{
   RowBox[{"p_", 
    RowBox[{"(", 
     RowBox[{"q_", "+", "r_"}], ")"}]}], " ", "->", " ", 
   RowBox[{
    RowBox[{"p", " ", "q"}], "+", 
    RowBox[{"p", " ", "r"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9856473208641567`*^9, 3.985647357489786*^9}, {
   3.985647390191799*^9, 3.9856474024627705`*^9}, {3.9856481865903435`*^9, 
   3.985648188475483*^9}, {3.985648225580513*^9, 3.9856482587707386`*^9}, 
   3.985649197531719*^9},
 CellLabel->
  "In[192]:=",ExpressionUUID->"68a317ce-d5a7-a949-8c22-96649577197a"],

Cell[BoxData[
 RowBox[{"2", "+", 
  RowBox[{"2", " ", "a"}], "+", 
  RowBox[{"2", " ", 
   SuperscriptBox["a", "2"]}], "+", 
  RowBox[{"2", " ", "b"}], "+", 
  RowBox[{"2", " ", "a", " ", "b"}], "+", "x", "+", 
  RowBox[{"a", " ", "x"}], "+", 
  RowBox[{
   SuperscriptBox["a", "2"], " ", "x"}], "+", 
  RowBox[{"b", " ", "x"}], "+", 
  RowBox[{"a", " ", "b", " ", "x"}], "+", "y", "+", 
  RowBox[{"a", " ", "y"}], "+", 
  RowBox[{
   SuperscriptBox["a", "2"], " ", "y"}], "+", 
  RowBox[{"b", " ", "y"}], "+", 
  RowBox[{"a", " ", "b", " ", "y"}]}]], "Output",
 CellChangeTimes->{3.9856474064351273`*^9, 3.985648189266218*^9, 
  3.985648227882225*^9, 3.9856482592737103`*^9, 3.9856491988304787`*^9},
 CellLabel->
  "Out[192]=",ExpressionUUID->"1f7ca2c7-fd83-b24c-b55a-4f4477f8ec72"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\

Exercise2
Write a rule-based program to apply sum and multiple angle identities for the \
cosine function, using ReplaceRepeated, a rule to replace any expression of \
the form Cos[p_+q_] with Cos[p]Cos[q]-Sin[p]Sin[q], and a rule to replace any \
expression of the form Cos[n_Integerp_] with \
Cos[p]Cos[(n-1)p]-Sin[p]Sin[(n-1)p]\
\>", "Subsection",
 CellChangeTimes->{{3.98564827781563*^9, 
  3.9856483198584995`*^9}},ExpressionUUID->"ca9dda84-d9c1-3c43-a81c-\
9d13ad7666e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", 
   RowBox[{
    RowBox[{"2", "x"}], "-", "y"}], "]"}], " ", "//.", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"p_", "+", "q_"}], "]"}], " ", ":>", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "p", "]"}], " ", 
       RowBox[{"Cos", "[", "q", "]"}]}], "-", 
      RowBox[{
       RowBox[{"Sin", "[", "p", "]"}], " ", 
       RowBox[{"Sin", "[", "q", "]"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"n_Integer", " ", "p_"}], "]"}], ":>", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "p", "]"}], 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}], "p"}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"Sin", "[", "p", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}], "p"}], "]"}]}]}]}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.9856483432152233`*^9, 3.985648345600544*^9}, {
   3.9856483898533707`*^9, 3.9856484038246155`*^9}, {3.9856484345205784`*^9, 
   3.9856485073601284`*^9}, {3.9856485632551975`*^9, 3.985648632322342*^9}, {
   3.9856488122760315`*^9, 3.9856488867690105`*^9}, {3.9856489187146416`*^9, 
   3.98564891992626*^9}, {3.9856492369518948`*^9, 3.9856492559917336`*^9}, {
   3.9856492943471203`*^9, 3.9856492970175896`*^9}, 3.9856493800807323`*^9},
 CellLabel->
  "In[197]:=",ExpressionUUID->"0b5aa896-d5c3-6a41-9d1d-1cb4004b8dda"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", "y", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"], "-", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], ")"}]}], "+", 
  RowBox[{
   RowBox[{"Sin", "[", 
    RowBox[{"2", " ", "x"}], "]"}], " ", 
   RowBox[{"Sin", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{{3.9856484044594917`*^9, 3.985648436901003*^9}, 
   3.9856485097316914`*^9, {3.985648566233061*^9, 3.9856485772391396`*^9}, {
   3.9856486122164974`*^9, 3.985648639873596*^9}, {3.9856488649289417`*^9, 
   3.9856488873164616`*^9}, 3.985648920891659*^9, {3.9856492505373535`*^9, 
   3.98564925647386*^9}, 3.9856492975569954`*^9, 3.9856494058709183`*^9},
 CellLabel->
  "Out[197]=",ExpressionUUID->"da43a5fe-86f0-c643-a65f-5d53af6ba95a"]
}, Open  ]],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.985649329212061*^9, 3.985649357219881*^9}, {
  3.985649410024908*^9, 
  3.9856494191771584`*^9}},ExpressionUUID->"2e688ed8-17a8-f346-9eb9-\
19c568a22b79"]
