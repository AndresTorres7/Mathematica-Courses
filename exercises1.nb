Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"IntegerQ", "[", "#", "]"}], ",", 
      RowBox[{"2", " ", "#"}], ",", "#"}], "]"}], "&"}], ",", 
   RowBox[{"{", 
    RowBox[{"2", ",", "Pi", ",", "5"}], "}"}]}], "]"}]], "Input",
