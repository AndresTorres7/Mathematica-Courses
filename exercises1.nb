Cell[CellGroupData[{

Cell["\<\
Exercise3
Use Nest and ReplaceAll to apply the rules {f[0]\[Rule]0,f[p_]\[Rule]f[p-1]} \
to the expression {f[3],f[11],f[\[Pi]]} exactly five times\
\>", "Subsection",
 CellChangeTimes->{{3.9856489533946037`*^9, 
  3.985648960581131*^9}},ExpressionUUID->"423031d7-bdd5-d545-8190-\
e9a2828dbb20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", "0", "]"}], "\[Rule]", "0"}], ",", 
      RowBox[{
       RowBox[{"f", "[", "p_", "]"}], "\[Rule]", 
       RowBox[{"f", "[", 
        RowBox[{"p", "-", "1"}], "]"}]}]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "3", "]"}], ",", 
     RowBox[{"f", "[", "11", "]"}], ",", 
     RowBox[{"f", "[", "\[Pi]", "]"}]}], "}"}], ",", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.9856490433776073`*^9, 3.9856490629616528`*^9}, {
  3.9856491013371677`*^9, 3.9856491305223217`*^9}, {3.985649223615881*^9, 
  3.985649226823122*^9}},
 CellLabel->
  "In[191]:=",ExpressionUUID->"a48cdada-a6d4-1f45-94e4-87c844c514bb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "2", ",", 
   RowBox[{
    RowBox[{"-", "3"}], "+", "\[Pi]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9856491429285126`*^9},
 CellLabel->
  "Out[191]=",ExpressionUUID->"9e5fbb1b-deca-d14f-ba89-52ab6af2babb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"#", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", "0", "]"}], "->", "0"}], ",", 
        RowBox[{
         RowBox[{"f", "[", "p_", "]"}], "->", 
         RowBox[{"f", "[", 
          RowBox[{"p", "-", "1"}], "]"}]}]}], "}"}]}], ")"}], "&"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "3", "]"}], ",", 
     RowBox[{"f", "[", "11", "]"}], ",", 
     RowBox[{"f", "[", "\[Pi]", "]"}]}], "}"}], ",", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.985649453346548*^9, 3.985649453346548*^9}},
 CellLabel->
  "In[202]:=",ExpressionUUID->"1cf05f58-075a-c54e-95f1-23d1427c1008"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "2", ",", 
   RowBox[{
    RowBox[{"-", "3"}], "+", "\[Pi]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.985649568416685*^9, 3.985649600849455*^9},
 CellLabel->
  "Out[202]=",ExpressionUUID->"91596cff-93b6-6441-8d01-f66bccbf5a39"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
