Cell["\<\

Exercise3
Assign a pure function as the value of a new symbol f  so that 
Map[f,{10,11,12,13,14,15,16}]  gives the same result as this program:
Map[Function[x,If[#1<3,#1,#2[#1-3,#2]]&[x,If[#1<3,#1,#2[#1-3,#2]]&]],{10,11,\
12,13,14,15,16}]
{1,2,0,1,2,0,1}\
\>", "Subsection",
 CellChangeTimes->{{3.985629716712618*^9, 
  3.985629732532894*^9}},ExpressionUUID->"09b4533c-deed-2643-ab36-\
baf67d80f5ae"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"#1", "<", "3"}], ",", "#1", ",", 
         RowBox[{"#2", "[", 
          RowBox[{
           RowBox[{"#1", "-", "3"}], ",", "#2"}], "]"}]}], "]"}], "&"}], "[", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#1", "<", "3"}], ",", "#1", ",", 
          RowBox[{"#2", "[", 
           RowBox[{
            RowBox[{"#1", "-", "3"}], ",", "#2"}], "]"}]}], "]"}], "&"}]}], 
      "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
    "10", ",", "11", ",", "12", ",", "13", ",", "14", ",", "15", ",", "16"}], 
    "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9856279200176296`*^9, 3.985627941060278*^9}, {
   3.985627979834528*^9, 3.9856279825598793`*^9}, {3.9856280601446686`*^9, 
   3.985628077430952*^9}, {3.9856281362938023`*^9, 3.985628200449856*^9}, {
   3.9856282462966137`*^9, 3.985628270973751*^9}, {3.9856283284508324`*^9, 
   3.985628341439253*^9}, {3.985628402267685*^9, 3.9856284192097073`*^9}, {
   3.9856284847774467`*^9, 3.9856284963186073`*^9}, {3.985628547965603*^9, 
   3.9856285894393673`*^9}, {3.9856286273279076`*^9, 
   3.9856286393365955`*^9}, {3.9856287050610466`*^9, 3.985628762664131*^9}, 
   3.9856288038727703`*^9, 3.9856297566772594`*^9},
 CellLabel->
  "In[141]:=",ExpressionUUID->"853bd084-6ce7-c345-9469-368c4e2aa4ed"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2", ",", "0", ",", "1", ",", "2", ",", "0", ",", "1"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.9856299413426514`*^9},
 CellLabel->
  "Out[141]=",ExpressionUUID->"31e3b0d0-93dd-5941-ad92-d320ed22e1db"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", " ", "=", " ", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"#", "<", "3"}], ",", "#", ",", 
      RowBox[{"f", "[", 
       RowBox[{"#", "-", "3"}], "]"}]}], " ", "]"}], " ", "&"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Map", "[", 
  RowBox[{"f", ",", 
   RowBox[{"{", 
    RowBox[{
    "10", ",", "11", ",", "12", ",", "13", ",", "14", ",", "15", ",", "16"}], 
    "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"clear", "[", "f", "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9856301826224937`*^9, 3.985630182623495*^9}, {
  3.9856302196383877`*^9, 3.9856302199340897`*^9}, {3.985630250189665*^9, 
  3.9856302840583267`*^9}, {3.9856304418884563`*^9, 3.985630557283161*^9}},
 CellLabel->
