   3.98564704734692*^9, 3.9856470653509064`*^9}, 3.9856471272417984`*^9, {
   3.9856472388476696`*^9, 3.985647267958893*^9}, {3.985648241389971*^9, 
   3.985648254159525*^9}},
 CellLabel->
  "Out[176]=",ExpressionUUID->"d1cd9c33-1a02-1b43-8661-ddbe7e20336f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", "b", "+", "1"}], ")"}], "a"}], "+", "b", "+", "1"}], 
    ")"}], 
   RowBox[{"(", 
    RowBox[{"x", "+", "y", "+", "2"}], ")"}]}], "//.", 
  RowBox[{
   RowBox[{"p_", 
    RowBox[{"(", 
     RowBox[{"q_", "+", "r_"}], ")"}]}], " ", "->", " ", 
   RowBox[{
    RowBox[{"p", " ", "q"}], "+", 
    RowBox[{"p", " ", "r"}]}]}]}]], "Input",
