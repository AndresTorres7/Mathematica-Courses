Cell[CellGroupData[{

Cell["\<\

Exercise2
Write a rule-based program to apply sum and multiple angle identities for the \
cosine function, using ReplaceRepeated, a rule to replace any expression of \
the form Cos[p_+q_] with Cos[p]Cos[q]-Sin[p]Sin[q], and a rule to replace any \
expression of the form Cos[n_Integerp_] with \
Cos[p]Cos[(n-1)p]-Sin[p]Sin[(n-1)p]\
\>", "Subsection",
 CellChangeTimes->{{3.98564827781563*^9, 
  3.9856483198584995`*^9}},ExpressionUUID->"c7b22823-75d4-964e-95ef-\
14a5becd85bc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", 
   RowBox[{
    RowBox[{"2", "x"}], "-", "y"}], "]"}], " ", "//.", " ", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"p_", "+", "q_"}], "]"}], " ", ":>", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "p", "]"}], " ", 
       RowBox[{"Cos", "[", "q", "]"}]}], "-", 
      RowBox[{
       RowBox[{"Sin", "[", "p", "]"}], " ", 
       RowBox[{"Sin", "[", "q", "]"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"n_Integer", " ", "p_"}], "]"}], ":>", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Cos", "[", "p", "]"}], 
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}], "p"}], "]"}]}], "-", 
      RowBox[{
       RowBox[{"Sin", "[", "p", "]"}], 
       RowBox[{"Sin", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}], "p"}], "]"}]}]}]}]}], 
   "}"}]}]], "Input",
 CellChangeTimes->{{3.9856483432152233`*^9, 3.985648345600544*^9}, {
   3.9856483898533707`*^9, 3.9856484038246155`*^9}, {3.9856484345205784`*^9, 
   3.9856485073601284`*^9}, {3.9856485632551975`*^9, 3.985648632322342*^9}, {
   3.9856488122760315`*^9, 3.9856488867690105`*^9}, {3.9856489187146416`*^9, 
   3.98564891992626*^9}, {3.9856492369518948`*^9, 3.9856492559917336`*^9}, {
   3.9856492943471203`*^9, 3.9856492970175896`*^9}, 3.9856493800807323`*^9},
 CellLabel->
  "In[197]:=",ExpressionUUID->"15620f84-b2bb-3943-844b-3a3970c6008b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", "y", "]"}], " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"Cos", "[", "x", "]"}], "2"], "-", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "x", "]"}], "2"]}], ")"}]}], "+", 
  RowBox[{
   RowBox[{"Sin", "[", 
    RowBox[{"2", " ", "x"}], "]"}], " ", 
   RowBox[{"Sin", "[", "y", "]"}]}]}]], "Output",
 CellChangeTimes->{{3.9856484044594917`*^9, 3.985648436901003*^9}, 
   3.9856485097316914`*^9, {3.985648566233061*^9, 3.9856485772391396`*^9}, {
   3.9856486122164974`*^9, 3.985648639873596*^9}, {3.9856488649289417`*^9, 
   3.9856488873164616`*^9}, 3.985648920891659*^9, {3.9856492505373535`*^9, 
   3.98564925647386*^9}, 3.9856492975569954`*^9, 3.9856494058709183`*^9},
 CellLabel->
  "Out[197]=",ExpressionUUID->"e2b9d3b4-150e-5a45-b856-2fb4cf4c9139"]
}, Open  ]],

