Cell[CellGroupData[{

Cell["\<\
Exercise1
Set an attribute for a symbol f so that f[{1,2},{3,4}] evaluates to \
{f[1,3],f[2,4]}
.\
\>", "Subsection",
 CellChangeTimes->{{3.9856523125196857`*^9, 
  3.9856523221785736`*^9}},ExpressionUUID->"d3bcfd38-6b92-e343-8fb7-\
a9a766c3409d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "Listable"}], "]"}], "\[IndentingNewLine]", 
