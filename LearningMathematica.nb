Cell[CellGroupData[{

Cell["\<\
Exercise2
Define a rule for f[x_Symbol,p_] that assigns ToString[p] where p is \
evaluated, and that works even if 
x already has a global value; for example:\
\>", "Subsection",
 CellChangeTimes->{{3.985820393635952*^9, 
  3.985820407639246*^9}},ExpressionUUID->"7ed9e95f-03cd-de49-8494-\
34714993be00"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{"x", ",", 
    RowBox[{"Table", "[", 
     RowBox[{"k", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "3"}], "}"}]}], "]"}]}], "]"}], ";", "x"}]], "Input",
 CellChangeTimes->{{3.9858204119251976`*^9, 
  3.9858204119251976`*^9}},ExpressionUUID->"80d01212-1ef0-434a-821f-\
96d169540d0c"],

