Cell[CellGroupData[{

Cell["\<\

Define a function S[p_] that holds the argument p unevaluated and that \
returns the list {Hold[p],p}. For example, the definition of S should give: \
S[2+2]   {Hold[2+2],4}\
\>", "Subsection",
 CellChangeTimes->{{3.985653099655575*^9, 
  3.985653138828144*^9}},ExpressionUUID->"6d33f333-112d-4042-9f3d-\
fe76afbd56a5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"S", ",", "HoldFirst"}], "]"}], ";", 
  RowBox[{
   RowBox[{"S", "[", "p_", "]"}], " ", ":=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Hold", "[", "p", "]"}], ",", " ", "p"}], "}"}]}]}], "\[IndentingNewLine]", 
