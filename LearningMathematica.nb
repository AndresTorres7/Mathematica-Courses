Cell[CellGroupData[{

Cell["\<\

Exercise2
Use TabView to set up a display with tabs to choose among displaying a \
graphic containing a disk, a circle or a triangle (
Graphics[Disk[]] , Graphics[Circle[]], Graphics[Triangle[]]).\
\>", "Subsection",
