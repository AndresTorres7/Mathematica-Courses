Cell[CellGroupData[{

Cell["\<\

Exercise4
Define a rule for f[p_List,n_Integer] that returns Table[pn,{x,5}], where pn \
is the element at position n
 in the list p, and that will work even if x has a global value, and without \
evaluating any other elements in 
p. For example:\
\>", "Subsection",
 CellChangeTimes->{{3.985818925438381*^9, 
  3.9858189397304726`*^9}},ExpressionUUID->"e3dfc400-e485-af4e-a2cd-\
949fa311afee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", 
      SuperscriptBox["x", "2"], ",", 
      RowBox[{"Abort", "[", "]"}]}], "}"}], ",", "2"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9858189487413635`*^9, 
  3.9858189487413635`*^9}},ExpressionUUID->"4354d70a-779c-384a-8826-\
4641006953a0"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.98581811827046*^9, 
  3.9858181291932983`*^9}},ExpressionUUID->"4320aa3f-cd2a-9045-b9c3-\
9d51d0b3346c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldAll"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"p_List", ",", "n_Integer"}], "]"}], ":=", 
  RowBox[{"Extract", "[", 
   RowBox[{
    RowBox[{"Unevaluated", "[", "p", "]"}], ",", "n", ",", 
    RowBox[{"Function", "[", 
     RowBox[{"pn", ",", 
      RowBox[{"Table", "[", 
       RowBox[{"pn", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "5"}], "}"}]}], "]"}], ",", "HoldAll"}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"x", "^", "2"}], ",", 
      RowBox[{"Abort", "[", "]"}]}], "}"}], ",", "2"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", 
  RowBox[{"f", ",", "x"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9858202856050873`*^9, 3.9858202963673306`*^9}},
 CellLabel->
  "In[259]:=",ExpressionUUID->"0b999f2f-5f33-3544-8472-31c335e7ff96"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "9", ",", "16", ",", "25"}], "}"}]], "Output",
 CellChangeTimes->{3.985820296979761*^9},
 CellLabel->
  "Out[261]=",ExpressionUUID->"7dd368b5-99cd-2745-bc24-69697a792314"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

