Cell[CellGroupData[{

Cell["\<\
Exercise3
Use Nest and ReplaceAll to apply the rules {f[0]\[Rule]0,f[p_]\[Rule]f[p-1]} \
to the expression {f[3],f[11],f[\[Pi]]} exactly five times\
\>", "Subsection",
 CellChangeTimes->{{3.9856489533946037`*^9, 
  3.985648960581131*^9}},ExpressionUUID->"ce6aee33-bfc7-c643-a3f6-\
62126e1cbb95"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{"ReplaceAll", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", "0", "]"}], "\[Rule]", "0"}], ",", 
      RowBox[{
       RowBox[{"f", "[", "p_", "]"}], "\[Rule]", 
       RowBox[{"f", "[", 
        RowBox[{"p", "-", "1"}], "]"}]}]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "3", "]"}], ",", 
     RowBox[{"f", "[", "11", "]"}], ",", 
     RowBox[{"f", "[", "\[Pi]", "]"}]}], "}"}], ",", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.9856490433776073`*^9, 3.9856490629616528`*^9}, {
  3.9856491013371677`*^9, 3.9856491305223217`*^9}, {3.985649223615881*^9, 
  3.985649226823122*^9}},
 CellLabel->
  "In[191]:=",ExpressionUUID->"a82f0bd6-19be-eb4c-bead-336c015eac14"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "2", ",", 
   RowBox[{
    RowBox[{"-", "3"}], "+", "\[Pi]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.9856491429285126`*^9},
 CellLabel->
  "Out[191]=",ExpressionUUID->"30e8894b-7472-5f44-aa9d-b4ebf78a93fe"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{"#", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"f", "[", "0", "]"}], "->", "0"}], ",", 
        RowBox[{
         RowBox[{"f", "[", "p_", "]"}], "->", 
         RowBox[{"f", "[", 
          RowBox[{"p", "-", "1"}], "]"}]}]}], "}"}]}], ")"}], "&"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"f", "[", "3", "]"}], ",", 
     RowBox[{"f", "[", "11", "]"}], ",", 
     RowBox[{"f", "[", "\[Pi]", "]"}]}], "}"}], ",", "5"}], "]"}]], "Input",
 CellChangeTimes->{{3.985649453346548*^9, 3.985649453346548*^9}},
 CellLabel->
  "In[202]:=",ExpressionUUID->"629b8671-fc9e-d54b-90f4-74dd3eca9db5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "2", ",", 
   RowBox[{
    RowBox[{"-", "3"}], "+", "\[Pi]"}]}], "}"}]], "Output",
 CellChangeTimes->{3.985649568416685*^9, 3.985649600849455*^9},
 CellLabel->
