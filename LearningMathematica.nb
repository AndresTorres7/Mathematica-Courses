      RowBox[{"First", "[", 
       RowBox[{"Timing", "[", 
        RowBox[{"f", "[", "n", "]"}], "]"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "30"}], "}"}]}], "]"}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
