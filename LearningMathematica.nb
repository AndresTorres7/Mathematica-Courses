 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldAll"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "p_", "]"}], ":=", 
  RowBox[{"Head", "[", 
   RowBox[{"Unevaluated", "[", "p", "]"}], "]"}]}], "\[IndentingNewLine]", 
