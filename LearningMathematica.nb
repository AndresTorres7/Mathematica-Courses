Exercise3
Assign a pure function as the value of a new symbol f  so that 
Map[f,{10,11,12,13,14,15,16}]  gives the same result as this program:
Map[Function[x,If[#1<3,#1,#2[#1-3,#2]]&[x,If[#1<3,#1,#2[#1-3,#2]]&]],{10,11,\
12,13,14,15,16}]
{1,2,0,1,2,0,1}\
\>", "Subsection",
 CellChangeTimes->{{3.985629716712618*^9, 
  3.985629732532894*^9}},ExpressionUUID->"47167917-7497-8443-ae7d-\
b4b935da1412"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Map", "[", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"#1", "<", "3"}], ",", "#1", ",", 
         RowBox[{"#2", "[", 
          RowBox[{
           RowBox[{"#1", "-", "3"}], ",", "#2"}], "]"}]}], "]"}], "&"}], "[", 
      RowBox[{"x", ",", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#1", "<", "3"}], ",", "#1", ",", 
          RowBox[{"#2", "[", 
           RowBox[{
            RowBox[{"#1", "-", "3"}], ",", "#2"}], "]"}]}], "]"}], "&"}]}], 
      "]"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
    "10", ",", "11", ",", "12", ",", "13", ",", "14", ",", "15", ",", "16"}], 
    "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9856279200176296`*^9, 3.985627941060278*^9}, {
   3.985627979834528*^9, 3.9856279825598793`*^9}, {3.9856280601446686`*^9, 
   3.985628077430952*^9}, {3.9856281362938023`*^9, 3.985628200449856*^9}, {
   3.9856282462966137`*^9, 3.985628270973751*^9}, {3.9856283284508324`*^9, 
