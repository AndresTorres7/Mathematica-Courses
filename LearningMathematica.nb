Cell[CellGroupData[{

Cell["\<\

Exercise3\
\>", "Subsection",
 CellChangeTimes->{
  3.985653677611452*^9},ExpressionUUID->"66274175-f7da-094a-bb30-\
fceb1d53e4cc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Hold", "[", 
   RowBox[{
    RowBox[{"Echo", "[", "2", "]"}], ",", 
    RowBox[{"Echo", "[", "1", "]"}]}], "]"}], "/.", 
  RowBox[{
   RowBox[{"Hold", "[", 
    RowBox[{"p_", ",", "q_"}], "]"}], ":>", 
   RowBox[{"With", "[", 
    RowBox[{
