  RowBox[{"Nest", "[", 
   RowBox[{
    RowBox[{"Function", "[", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"Sow", "[", "x", "]"}], "+", "1"}]}], "]"}], ",", "0", ",", 
    "10"}], "]"}], "]"}]], "Input",
