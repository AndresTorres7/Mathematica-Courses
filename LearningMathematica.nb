Cell[CellGroupData[{

Cell["\<\

Exercise1
Write a rule-based program to do what the Expand function does, using \
ReplaceRepeated and a rule that replaces any expression of the form p_(q_+r_) \
 with pq+pr.\
\>", "Subsection",
 CellChangeTimes->{{3.985646877478819*^9, 3.9856468867186775`*^9}, {
  3.9856469249123306`*^9, 
  3.98564692751713*^9}},ExpressionUUID->"7832422d-993e-1a49-a66f-\
eb19005e3fed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Expand", "[", 
  RowBox[{"5", 
   RowBox[{"(", 
    RowBox[{"x", "+", "3"}], ")"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.985646931403635*^9, 3.9856469829127274`*^9}, {
  3.985647024635311*^9, 3.9856470648619556`*^9}, {3.9856470984678936`*^9, 
  3.9856471261131954`*^9}, {3.9856472432421284`*^9, 3.985647267284004*^9}, {
