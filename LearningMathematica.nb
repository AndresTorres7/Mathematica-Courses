Cell[CellGroupData[{

Cell["\<\
Exercise1
Make a Manipulate that displays Graphics[{c,Disk[]}] and with a \
RadioButtonBar control for setting the value of c
 to Blue, Green or Blue.\
\>", "Subsection",
 CellChangeTimes->{{3.9857351436027718`*^9, 
  3.9857351618418503`*^9}},ExpressionUUID->"138de9d6-c14c-484a-8f63-\
e68ba502cc93"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Graphics", "[", 
    RowBox[{"{", 
     RowBox[{"c", ",", 
      RowBox[{"Disk", "[", "]"}]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"c", ",", 
     RowBox[{"{", 
      RowBox[{"Blue", ",", "Green", ",", "Red"}], "}"}]}], "}"}], ",", 
   RowBox[{"ControlType", "->", " ", "RadioButtonBar"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9857417293712482`*^9, 3.9857417293712482`*^9}, {
