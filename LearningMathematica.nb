Cell[BoxData[
 RowBox[{"2", "+", 
  RowBox[{"2", " ", "a"}], "+", 
  RowBox[{"2", " ", 
   SuperscriptBox["a", "2"]}], "+", 
  RowBox[{"2", " ", "b"}], "+", 
  RowBox[{"2", " ", "a", " ", "b"}], "+", "x", "+", 
  RowBox[{"a", " ", "x"}], "+", 
