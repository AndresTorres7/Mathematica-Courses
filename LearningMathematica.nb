 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldFirst"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"x_Symbol", ",", "p_"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{"x", "=", 
    RowBox[{"ToString", "[", "p", "]"}]}], ")"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{"x", ",", 
    RowBox[{"Table", "[", 
     RowBox[{"k", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "3"}], "}"}]}], "]"}]}], "]"}], ";", "x"}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", 
  RowBox[{"f", ",", "x"}], "]"}]}], "Input",
