 RowBox[{
  RowBox[{"x", "=", 
   RowBox[{"{", 
    RowBox[{
    "0", ",", "1", ",", "2", ",", "0", ",", "1", ",", "2", ",", "0", ",", "1",
      ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Do", "[", 
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "==", "1"}], ",", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"[", "k", "]"}], "]"}], "=", "Nothing"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", 
     RowBox[{"Length", "[", "x", "]"}]}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", "x"}], "Input",
