544e7cebf515"],

Cell[CellGroupData[{

Cell["\<\
Exercise1
Use Module to modify this definition of f[p_] to localize all of the \
variables that are not already local to the definition:\
\>", "Subsection",
 CellChangeTimes->{{3.9857061718473225`*^9, 
  3.9857061766212883`*^9}},ExpressionUUID->"23694875-1add-7043-8f4e-\
554ab0099613"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"p_Integer", "?", "Positive"}], "]"}], ":=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"k", "=", 
     RowBox[{"\[Pi]", "/", "2"}]}], ";", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"n", " ", "k"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"n", ",", "0", ",", "p"}], "}"}]}], "]"}]}], ")"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"p_Integer", "?", "Positive"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "k", "}"}], ",", 
     RowBox[{
      RowBox[{"k", "=", 
       RowBox[{"\[Pi]", "/", "2"}]}], ";", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Sin", "[", 
         RowBox[{"n", " ", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", "0", ",", "p"}], "}"}]}], "]"}]}]}], "]"}]}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "f", "]"}]}], "Input",
 CellChangeTimes->{{3.9857061946438446`*^9, 3.9857061946438446`*^9}, {
