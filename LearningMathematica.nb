Cell[CellGroupData[{

Cell["\<\

Exercise2
Modify this program using Monitor and ProgressIndicator so that a progress \
indicator bar showing the current value of k is displayed while the program \
is running:\
\>", "Subsection",
 CellChangeTimes->{{3.9858055810541286`*^9, 
  3.9858055920655212`*^9}},ExpressionUUID->"6ae934d0-2a6d-ca4b-bd6c-\
319a99334138"],

Cell[BoxData[
 RowBox[{
  RowBox[{"result", "=", "0"}], ";", 
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", 
    RowBox[{"k", "<=", "10"}], ",", 
    RowBox[{"k", "++"}], ",", 
    RowBox[{
     RowBox[{"result", "=", 
      RowBox[{"result", "+", "k"}]}], ";", 
     RowBox[{"Pause", "[", "0.2", "]"}]}]}], "]"}], ";", "result", 
  " "}]], "Input",
 CellChangeTimes->{{3.985805600035473*^9, 
  3.985805600035473*^9}},ExpressionUUID->"40c1bff2-17cb-464d-ba59-\
b3dff9b59d25"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Monitor", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"result", "=", "0"}], ";", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"k", "=", "0"}], ",", 
      RowBox[{"k", "<=", "10"}], ",", 
      RowBox[{"k", "++"}], ",", 
      RowBox[{
