Cell[CellGroupData[{

Cell["\<\
Exercise1
Use Reap and Sow to modify this program so that the result of the evaluation \
includes the list of 
x\[CloseCurlyQuote]s that come up during the calculation:\
\>", "Subsection",
 CellChangeTimes->{{3.9858055593360233`*^9, 
  3.985805565022274*^9}},ExpressionUUID->"824a6fcd-f99c-1541-9a71-\
342331ac223e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Nest", "[", 
  RowBox[{
   RowBox[{"Function", "[", 
    RowBox[{"x", ",", 
     RowBox[{"x", "+", "1"}]}], "]"}], ",", "0", ",", "10"}], "]"}]], "Input",
