 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldAll"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "p_", "]"}], ":=", 
  RowBox[{"Head", "[", 
   RowBox[{"Unevaluated", "[", "p", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{"2", "+", "2"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{"Abort", "[", "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{"Timing", "[", "]"}], "]"}]}], "Input",
