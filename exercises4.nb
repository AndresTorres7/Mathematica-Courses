Cell[CellGroupData[{

Cell["\<\

Exercise1
Define a function f that takes one argument and that returns the head of that \
argument; for example:\
\>", "Subsection",
 CellChangeTimes->{{3.9858203375467606`*^9, 
  3.985820339959875*^9}},ExpressionUUID->"a101b7f5-db58-0943-a4fe-\
7591220cbd7e"],

