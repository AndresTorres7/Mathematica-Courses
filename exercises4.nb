Cell[CellGroupData[{

Cell["\<\

Exercise2
Modify this program using Monitor and ProgressIndicator so that a progress \
indicator bar showing the current value of k is displayed while the program \
is running:\
\>", "Subsection",
 CellChangeTimes->{{3.9858055810541286`*^9, 
  3.9858055920655212`*^9}},ExpressionUUID->"406f8443-1537-4a43-8331-\
8c97df927d54"],

Cell[BoxData[
 RowBox[{
  RowBox[{"result", "=", "0"}], ";", 
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", 
    RowBox[{"k", "<=", "10"}], ",", 
    RowBox[{"k", "++"}], ",", 
    RowBox[{
     RowBox[{"result", "=", 
      RowBox[{"result", "+", "k"}]}], ";", 
     RowBox[{"Pause", "[", "0.2", "]"}]}]}], "]"}], ";", "result", 
  " "}]], "Input",
 CellChangeTimes->{{3.985805600035473*^9, 
  3.985805600035473*^9}},ExpressionUUID->"a536d9fd-46bc-024b-9ef4-\
267df473bd71"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Monitor", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"result", "=", "0"}], ";", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"k", "=", "0"}], ",", 
      RowBox[{"k", "<=", "10"}], ",", 
      RowBox[{"k", "++"}], ",", 
      RowBox[{
       RowBox[{"result", "=", 
        RowBox[{"result", "+", "k"}]}], ";", 
       RowBox[{"Pause", "[", "0.2", "]"}]}]}], "]"}], ";", "result"}], " ", ",", 
   RowBox[{"ProgressIndicator", "[", 
    RowBox[{"k", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "10"}], "}"}]}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.985806132386553*^9, 3.9858061602121716`*^9}},
 CellLabel->
  "In[228]:=",ExpressionUUID->"f6d7f2a8-aef1-ca48-ac31-fef304570d2d"],

