 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{"x", ",", 
    RowBox[{"Table", "[", 
     RowBox[{"k", ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "3"}], "}"}]}], "]"}]}], "]"}], ";", "x"}]], "Input",
 CellChangeTimes->{{3.9858204119251976`*^9, 
  3.9858204119251976`*^9}},ExpressionUUID->"4981f66b-b865-3842-bff8-\
