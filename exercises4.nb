Cell[CellGroupData[{

Cell["\<\

Exercise4
Define a rule for f[p_List,n_Integer] that returns Table[pn,{x,5}], where pn \
is the element at position n
 in the list p, and that will work even if x has a global value, and without \
evaluating any other elements in 
p. For example:\
\>", "Subsection",
 CellChangeTimes->{{3.985818925438381*^9, 
  3.9858189397304726`*^9}},ExpressionUUID->"2178faa4-7e0f-a243-be75-\
ad8bdfc97f2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", 
      SuperscriptBox["x", "2"], ",", 
      RowBox[{"Abort", "[", "]"}]}], "}"}], ",", "2"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9858189487413635`*^9, 
  3.9858189487413635`*^9}},ExpressionUUID->"6d90f9e0-bb0c-934f-a578-\
434bd00c9f51"],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.98581811827046*^9, 
  3.9858181291932983`*^9}},ExpressionUUID->"9f21a19f-f201-e04b-a63e-\
374fedc93293"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"SetAttributes", "[", 
  RowBox[{"f", ",", "HoldAll"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"p_List", ",", "n_Integer"}], "]"}], ":=", 
  RowBox[{"Extract", "[", 
   RowBox[{
    RowBox[{"Unevaluated", "[", "p", "]"}], ",", "n", ",", 
    RowBox[{"Function", "[", 
     RowBox[{"pn", ",", 
      RowBox[{"Table", "[", 
       RowBox[{"pn", ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "5"}], "}"}]}], "]"}], ",", "HoldAll"}], "]"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"x", "=", "99"}], ";", 
  RowBox[{"f", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"x", "^", "2"}], ",", 
      RowBox[{"Abort", "[", "]"}]}], "}"}], ",", "2"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", 
  RowBox[{"f", ",", "x"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9858202856050873`*^9, 3.9858202963673306`*^9}},
 CellLabel->
  "In[259]:=",ExpressionUUID->"507f021d-8782-f641-b46a-1ee8fe9791e2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "9", ",", "16", ",", "25"}], "}"}]], "Output",
 CellChangeTimes->{3.985820296979761*^9},
 CellLabel->
  "Out[261]=",ExpressionUUID->"96f86cc4-4d15-6748-ab94-1dd91772f3ba"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

